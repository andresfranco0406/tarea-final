# Matriz del menú
menu = [
    ["Hamburguesa", "Comida Rápida", 20000],
    ["Pizza", "Comida Rápida", 28000],
    ["Jugo Natural", "Bebida", 7000],
    ["Café", "Bebida", 4000],
    ["Pasta", "colombiana", 28000],
    ["Lasaña", "colombiana", 32000]
]

# Categoría objetivo y umbral
categoria_objetivo = "colombiana"
umbral = 25000

# Función para calcular precio final
def calcular_precio_final(categoria, precio):
    if categoria == categoria_objetivo and precio > umbral:
        return precio * 0.85  # descuento del 15%
    else:
        return precio

# Mostrar resultados
print("PRODUCTOS DEL MENÚ")
print("-" * 50)

for producto in menu:
    nombre = producto[0]
    categoria = producto[1]
    precio_base = producto[2]

    precio_final = calcular_precio_final(categoria, precio_base)

    print("Producto:", nombre)
    print("Categoría:", categoria)
    print("Precio Base: $", precio_base)
    print("Precio Final: $", precio_final)
    print("-" * 50)
